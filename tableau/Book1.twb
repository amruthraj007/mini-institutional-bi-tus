      <aliases enabled='yes' />
      <column caption='New Entrants' datatype='integer' name='[Calculation_346495740616716288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [entrant_flag] = 1 THEN [student_id] END)' />
      </column>
      <column caption='Institutional Retention Rate' datatype='real' name='[Calculation_346495740617117697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([retained_institution_next_year_flag])' />
      </column>
      <column caption='Same Programme Retention Rate' datatype='real' name='[Calculation_346495740617609218]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([retained_same_programme_next_year_flag])' />
      </column>
      <column caption='High Risk %' datatype='real' name='[Calculation_346495740617797635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [risk_band] = &apos;High&apos; THEN 1 ELSE 0 END)' />
      </column>
