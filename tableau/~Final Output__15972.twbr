              <calculation class='tableau' formula='AVG([retained_institution_next_year_flag])' />
            </column>
            <column caption='Success Score' datatype='real' name='[Calculation_346495740981669907]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(([gpa] / 4) * 100 * 0.5)&#13;&#10;+&#13;&#10;([attendance_rate] * 0.5)' />
            </column>
            <column caption='Risk Band (Success Score)' datatype='string' name='[Calculation_346495740983767060]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_346495740981669907] &gt;= 85 THEN &quot;Low&quot;&#13;&#10;ELSEIF [Calculation_346495740981669907] &gt;= 70 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
            </column>
            <column caption='academic year' datatype='string' name='[academic_year (Sheet12)]' role='dimension' type='nominal' />
            <column aggregation='Sum' caption='Access Flag' datatype='integer' name='[access_flag]' role='dimension' type='ordinal'>
              <aliases>
