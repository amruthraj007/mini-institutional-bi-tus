    <worksheet name='Risk Band Distribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='12'>Risk Band Distribution</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1+ (Multiple Connections)' name='federated.1x3anij073gq601djj3nh0psxlv1' />
          </datasources>
          <datasource-dependencies datasource='federated.1x3anij073gq601djj3nh0psxlv1'>
            <column caption='Success Score' datatype='real' name='[Calculation_346495740981669907]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(([gpa] / 4) * 100 * 0.5)&#13;&#10;+&#13;&#10;([attendance_rate] * 0.5)' />
            </column>
            <column caption='Risk Band (Success Score)' datatype='string' name='[Calculation_346495740983767060]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_346495740981669907] &gt;= 85 THEN &quot;Low&quot;&#13;&#10;ELSEIF [Calculation_346495740981669907] &gt;= 70 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
            </column>
            <column caption='Risk Band %' datatype='real' name='[Calculation_346495740985552917]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([student_id]) / TOTAL(COUNTD([student_id]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='academic year' datatype='string' name='[academic_year (Sheet12)]' role='dimension' type='nominal' />
            <column aggregation='Sum' caption='Access Flag' datatype='integer' name='[access_flag]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='Non-Access' />
                <alias key='1' value='Access' />
              </aliases>
            </column>
            <column caption='Attendance Rate' datatype='real' name='[attendance_rate]' role='measure' type='quantitative' />
            <column-instance column='[student_id]' derivation='CountD' name='[ctd:student_id:qk]' pivot='key' type='quantitative' />
            <column aggregation='Sum' caption='Entrant Flag' datatype='integer' name='[entrant_flag]' role='dimension' type='ordinal' />
            <column caption='Faculty' datatype='string' name='[faculty]' role='dimension' type='nominal' />
            <column caption='Gpa' datatype='real' name='[gpa]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_346495740983767060]' derivation='None' name='[none:Calculation_346495740983767060:nk]' pivot='key' type='nominal' />
            <column-instance column='[academic_year (Sheet12)]' derivation='None' name='[none:academic_year (Sheet12):nk]' pivot='key' type='nominal' />
            <column-instance column='[access_flag]' derivation='None' name='[none:access_flag:ok]' pivot='key' type='ordinal' />
            <column-instance column='[entrant_flag]' derivation='None' name='[none:entrant_flag:ok]' pivot='key' type='ordinal' />
            <column-instance column='[faculty]' derivation='None' name='[none:faculty:nk]' pivot='key' type='nominal' />
            <column-instance column='[risk_band]' derivation='None' name='[none:risk_band:nk]' pivot='key' type='nominal' />
            <column caption='Risk Band' datatype='string' name='[risk_band]' role='dimension' type='nominal' />
            <column caption='Student Id' datatype='string' name='[student_id]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_346495740985552917]' derivation='User' name='[usr:Calculation_346495740985552917:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' />
            </column-instance>
          </datasource-dependencies>
          <manual-sort column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:Calculation_346495740983767060:nk]' direction='ASC'>
            <dictionary>
              <bucket>&quot;Low&quot;</bucket>
              <bucket>&quot;Medium&quot;</bucket>
              <bucket>&quot;High&quot;</bucket>
            </dictionary>
          </manual-sort>
          <filter class='categorical' column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:academic_year (Sheet12):nk]'>
            <groupfilter function='member' level='[none:academic_year (Sheet12):nk]' member='&quot;2023/24&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:access_flag:ok]' filter-group='5'>
            <groupfilter function='level-members' level='[none:access_flag:ok]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:entrant_flag:ok]'>
            <groupfilter function='member' level='[none:entrant_flag:ok]' member='1' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:faculty:nk]' filter-group='4'>
            <groupfilter function='level-members' level='[none:faculty:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:risk_band:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:risk_band:nk]' member='&quot;High&quot;' />
