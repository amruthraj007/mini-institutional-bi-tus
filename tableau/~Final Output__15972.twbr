              <calculation class='tableau' formula='SUM(&#13;&#10;    IF [risk_band] = &quot;High&quot;&#13;&#10;    AND [retained_institution_next_year_flag] = 1&#13;&#10;    THEN 1 END&#13;&#10;)&#13;&#10;/&#13;&#10;SUM(&#13;&#10;    IF [risk_band] = &quot;High&quot; THEN 1 END&#13;&#10;)' />
