    <worksheet name='KPI - High-Risk Students'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontsize='10'>High Risk Students</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1+ (Multiple Connections)' name='federated.1x3anij073gq601djj3nh0psxlv1' />
          </datasources>
          <datasource-dependencies datasource='federated.1x3anij073gq601djj3nh0psxlv1'>
            <column caption='High Risk Students' datatype='integer' name='[Calculation_346495740973977614]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [Calculation_346495740983767060] = &quot;High&quot; THEN [student_id (Sheet11)] END&#13;&#10;)' />
            </column>
            <column caption='Success Score' datatype='real' name='[Calculation_346495740981669907]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(([gpa] / 4) * 100 * 0.5)&#13;&#10;+&#13;&#10;([attendance_rate] * 0.5)' />
            </column>
            <column caption='Risk Band (Success Score)' datatype='string' name='[Calculation_346495740983767060]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_346495740981669907] &gt;= 85 THEN &quot;Low&quot;&#13;&#10;ELSEIF [Calculation_346495740981669907] &gt;= 70 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
            </column>
            <column caption='academic year' datatype='string' name='[academic_year (Sheet12)]' role='dimension' type='nominal' />
            <column aggregation='Sum' caption='Access Flag' datatype='integer' name='[access_flag]' role='dimension' type='ordinal'>
              <aliases>
                <alias key='0' value='Non-Access' />
                <alias key='1' value='Access' />
              </aliases>
            </column>
            <column caption='Attendance Rate' datatype='real' name='[attendance_rate]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Entrant Flag' datatype='integer' name='[entrant_flag]' role='dimension' type='ordinal' />
            <column caption='Faculty' datatype='string' name='[faculty]' role='dimension' type='nominal' />
            <column caption='Gpa' datatype='real' name='[gpa]' role='measure' type='quantitative' />
            <column-instance column='[academic_year (Sheet12)]' derivation='None' name='[none:academic_year (Sheet12):nk]' pivot='key' type='nominal' />
            <column-instance column='[access_flag]' derivation='None' name='[none:access_flag:ok]' pivot='key' type='ordinal' />
            <column-instance column='[entrant_flag]' derivation='None' name='[none:entrant_flag:ok]' pivot='key' type='ordinal' />
            <column-instance column='[faculty]' derivation='None' name='[none:faculty:nk]' pivot='key' type='nominal' />
            <column caption='student id' datatype='string' name='[student_id (Sheet11)]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_346495740973977614]' derivation='User' name='[usr:Calculation_346495740973977614:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:academic_year (Sheet12):nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:academic_year (Sheet12):nk]' member='&quot;2020/21&quot;' />
              <groupfilter function='member' level='[none:academic_year (Sheet12):nk]' member='&quot;2021/22&quot;' />
              <groupfilter function='member' level='[none:academic_year (Sheet12):nk]' member='&quot;2022/23&quot;' />
