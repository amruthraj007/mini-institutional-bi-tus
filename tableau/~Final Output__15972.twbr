              <groupfilter function='member' level='[none:academic_year (Sheet12):nk]' member='&quot;2024/25&quot;' />
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.1x3anij073gq601djj3nh0psxlv1].[none:access_flag:ok]' filter-group='5'>
            <groupfilter function='level-members' level='[none:access_flag:ok]' user:ui-enumeration='all' user:ui-marker='enumerate' />
