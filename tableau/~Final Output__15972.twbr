      <aliases enabled='yes' />
      <column caption='Gap Direction' datatype='string' name='[Calculation_1123929626802405376]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Calculation_346495740946292748]) THEN &quot;&quot;&#13;&#10;ELSEIF [Calculation_346495740946292748] &gt; 0 THEN &quot;▲&quot;&#13;&#10;ELSEIF [Calculation_346495740946292748] &lt; 0 THEN &quot;▼&quot;&#13;&#10;ELSE &quot;–&quot;&#13;&#10;END' />
      </column>
      <column caption='Gap Display' datatype='string' name='[Calculation_1123929626802524161]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Calculation_346495740946292748]) THEN &quot;&quot;&#13;&#10;ELSE&#13;&#10;    IF [Calculation_346495740946292748] &gt; 0 THEN &quot;▲ &quot;&#13;&#10;    ELSEIF [Calculation_346495740946292748] &lt; 0 THEN &quot;▼ &quot;&#13;&#10;    ELSE &quot;&quot;&#13;&#10;    END&#13;&#10;    +&#13;&#10;    STR(ROUND([Calculation_346495740946292748] * 100,1))&#13;&#10;    + &quot; pp&quot;&#13;&#10;END' />
      </column>
      <column caption='New Entrants' datatype='integer' name='[Calculation_346495740616716288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [entrant_flag] = 1 THEN [student_id] END)' />
      </column>
      <column caption='Institutional Retention Rate' datatype='real' name='[Calculation_346495740617117697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([retained_institution_next_year_flag])' />
      </column>
      <column caption='Same Programme Retention Rate' datatype='real' name='[Calculation_346495740617609218]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([retained_same_programme_next_year_flag])' />
      </column>
      <column caption='Not Retained' datatype='integer' name='[Calculation_346495740770463748]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [entrant_flag] = 1 THEN [student_id] END&#13;&#10;) &#13;&#10;-&#13;&#10;SUM(&#13;&#10;    IF [entrant_flag] = 1 THEN [retained_institution_next_year_flag] END&#13;&#10;)' />
      </column>
      <column caption='Is Snapshot Cohort' datatype='boolean' name='[Calculation_346495740803923973]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[academic_year] = [Parameters].[Parameter 2]' />
      </column>
      <column caption='Programme Gap' datatype='real' name='[Calculation_346495740907237382]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_346495740617117697] - WINDOW_AVG([Calculation_346495740617117697])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Institutional (Year) Retention' datatype='real' name='[Calculation_346495740917415944]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [academic_year] :&#13;&#10;    SUM( IF [entrant_flag] = 1 THEN [retained_institution_next_year_flag] END )&#13;&#10;}&#13;&#10;/&#13;&#10;{ FIXED [academic_year] :&#13;&#10;    COUNTD( IF [entrant_flag] = 1 THEN [student_id] END )&#13;&#10;}' />
      </column>
      <column caption='Retention Gap (pp)' datatype='real' name='[Calculation_346495740933234697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_346495740617117697] - AVG([Calculation_346495740917415944])' />
      </column>
      <column caption='Programme Retention (Selected Only)' datatype='real' name='[Calculation_346495740943998986]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF MIN([programme_name]) = MAX([programme_name]) THEN&#13;&#10;    ([Calculation_346495740617117697])&#13;&#10;END' />
      </column>
      <column caption='Programme Entrants (Selected Only)' datatype='integer' name='[Calculation_346495740945129483]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF MIN([programme_name]) = MAX([programme_name]) THEN&#13;&#10;    ([Calculation_346495740616716288])&#13;&#10;END' />
      </column>
      <column caption='Retention Gap (Selected Only)' datatype='real' name='[Calculation_346495740946292748]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF MIN([programme_name]) = MAX([programme_name]) THEN&#13;&#10;    ([Calculation_346495740617117697]) - AVG([Calculation_346495740917415944])&#13;&#10;END' />
      </column>
      <column caption='Programme Retention (Trend Selected Only)' datatype='real' name='[Calculation_346495740948664333]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF MIN([programme_name]) = MAX([programme_name]) THEN&#13;&#10;    ([Calculation_346495740617117697])&#13;&#10;END' />
      </column>
      <column caption='High Risk Students' datatype='integer' name='[Calculation_346495740973977614]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;    IF [Calculation_346495740983767060] = &quot;High&quot; THEN [student_id (Sheet11)] END&#13;&#10;)' />
      </column>
      <column caption='Retention - High Risk' datatype='real' name='[Calculation_346495740975775760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [risk_band] = &quot;High&quot;&#13;&#10;    AND [retained_institution_next_year_flag] = 1&#13;&#10;    THEN 1 END&#13;&#10;)&#13;&#10;/&#13;&#10;SUM(&#13;&#10;    IF [risk_band] = &quot;High&quot; THEN 1 END&#13;&#10;)' />
      </column>
      <column caption='GPA (100 Scale)' datatype='real' name='[Calculation_346495740980461586]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([gpa] / 4) * 100' />
      </column>
      <column caption='Success Score' datatype='real' name='[Calculation_346495740981669907]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([gpa] / 4) * 100 * 0.5)&#13;&#10;+&#13;&#10;([attendance_rate] * 0.5)' />
      </column>
      <column caption='Risk Band (Success Score)' datatype='string' name='[Calculation_346495740983767060]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_346495740981669907] &gt;= 85 THEN &quot;Low&quot;&#13;&#10;ELSEIF [Calculation_346495740981669907] &gt;= 70 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;High&quot;&#13;&#10;END' />
      </column>
      <column caption='Risk Band %' datatype='real' name='[Calculation_346495740985552917]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([student_id]) / TOTAL(COUNTD([student_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='High Risk % Measure' datatype='real' name='[Calculation_346495740989095958]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Calculation_346495740983767060] = &quot;High&quot; THEN [student_id (Sheet11)] END)&#13;&#10;/&#13;&#10;COUNTD([student_id (Sheet11)])' />
      </column>
