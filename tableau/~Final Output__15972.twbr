            <column aggregation='Sum' caption='Entrant Flag' datatype='integer' name='[entrant_flag]' role='dimension' type='ordinal' />
            <column caption='Faculty' datatype='string' name='[faculty]' role='dimension' type='nominal' />
            <column caption='Gpa' datatype='real' name='[gpa]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_346495740983767060]' derivation='None' name='[none:Calculation_346495740983767060:nk]' pivot='key' type='nominal' />
            <column-instance column='[academic_year (Sheet12)]' derivation='None' name='[none:academic_year (Sheet12):nk]' pivot='key' type='nominal' />
            <column-instance column='[access_flag]' derivation='None' name='[none:access_flag:ok]' pivot='key' type='ordinal' />
            <column-instance column='[entrant_flag]' derivation='None' name='[none:entrant_flag:ok]' pivot='key' type='ordinal' />
            <column-instance column='[faculty]' derivation='None' name='[none:faculty:nk]' pivot='key' type='nominal' />
            <column caption='Retained Institution Next Year Flag' datatype='integer' name='[retained_institution_next_year_flag]' role='measure' type='quantitative' />
